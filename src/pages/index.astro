---
import { Image } from "astro:assets"
import { getCollection, type CollectionEntry } from "astro:content"
import HomeLayout from "../layouts/HomeLayout.astro"
import { resolveFeedVisual, type FeedColumn, type FeedVisual } from "../lib/feedCover.ts"
import {
  formatDate,
  hrefForDocId,
  isoDate,
  mtimeMs,
  publishedOrMtimeMs,
  dailyCardMenuTitle,
} from "../lib/homeLists.ts"

const BLOG_HOME_FEED_MAX = 20

const allDocs = await getCollection("docs", (e) => e.data.draft !== true)

type CardItem = {
  href: string
  title: string
  dateLabel: string
  dateIso: string
  description: string
  feed: FeedVisual
}

type CardItemOptions = {
  /** 覆盖卡片标题（如日刊为 `publishedAt` + `title`） */
  title?: (e: CollectionEntry<"docs">) => string
  /** 为 true 时不展示卡片上的日期行（标题已含日期时避免重复） */
  hideDate?: boolean
}

function toCardItems(
  entries: CollectionEntry<"docs">[],
  column: FeedColumn,
  timeMs: (e: CollectionEntry<"docs">) => number = (e) => mtimeMs(e.id),
  max = 12,
  opts?: CardItemOptions,
): CardItem[] {
  return entries.slice(0, max).map((e) => {
    const t = timeMs(e)
    const hideDate = opts?.hideDate === true
    return {
      href: hrefForDocId(e.id),
      title: opts?.title ? opts.title(e) : ((e.data.title ?? "") as string),
      dateLabel: hideDate ? "" : formatDate(t),
      dateIso: hideDate ? "" : isoDate(t),
      description: (e.data.description ?? "") as string,
      feed: resolveFeedVisual(e.data.feedCover, column, e.id),
    }
  })
}

const dailyRaw = allDocs.filter(
  (e) => /^daily\/\d{4}\//u.test(e.id) && e.id !== "daily/index" && !e.id.endsWith("/index"),
)
dailyRaw.sort((a, b) => publishedOrMtimeMs(b) - publishedOrMtimeMs(a))
const dailyList = toCardItems(dailyRaw, "daily", publishedOrMtimeMs, 12, {
  title: (e) => dailyCardMenuTitle(e.id, e.data),
  hideDate: true,
})

const blogCandidates = allDocs.filter((e) => e.id.startsWith("blog/") && e.id !== "blog/index")
const byPublishedDesc = (a: CollectionEntry<"docs">, b: CollectionEntry<"docs">) =>
  publishedOrMtimeMs(b) - publishedOrMtimeMs(a)
const blogFeatured = blogCandidates.filter((e) => e.data.homeFeed === true).sort(byPublishedDesc)
const blogRest = blogCandidates.filter((e) => e.data.homeFeed !== true).sort(byPublishedDesc)
/** 先 homeFeed，再按 publishedAt（无则 mtime）倒序补足至 20 条 */
const blogRaw = [...blogFeatured, ...blogRest].slice(0, BLOG_HOME_FEED_MAX)
const blogList = toCardItems(blogRaw, "blog", publishedOrMtimeMs, BLOG_HOME_FEED_MAX)

const base = import.meta.env.BASE_URL
const feedColumns = [
  { key: "daily", title: "日刊", moreHref: `${base}daily/`, items: dailyList },
  { key: "blog", title: "博客", moreHref: `${base}blog/`, items: blogList },
] as const
---

<HomeLayout title="摸鱼编程" description="摸鱼编程 — 日刊与博客">
  <main id="_top" class="home-main-inner">
    <div class="home-columns">
      {
        feedColumns.map((col) => (
          <section class="home-col" aria-labelledby={`home-${col.key}-heading`}>
            <h2 id={`home-${col.key}-heading`} class="home-col-title">
              {col.title}
            </h2>
            <div class="home-card-grid">
              {col.items.map((item) => (
                <a class="home-card" href={item.href}>
                  <div
                    class:list={["home-card-image", item.feed.kind === "none" && "home-card-image--empty"]}
                    aria-hidden={item.feed.kind === "none" ? true : undefined}
                  >
                    {item.feed.kind === "none" ? null : item.feed.kind === "raster" ? (
                      <Image src={item.feed.src} alt="" width={640} height={360} />
                    ) : (
                      <img
                        src={item.feed.src}
                        alt=""
                        width="640"
                        height="360"
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                  </div>
                  <div class="home-card-body">
                    <h3 class="home-card-title">{item.title}</h3>
                    {item.dateLabel && item.dateIso && (
                      <time class="home-card-date" datetime={item.dateIso}>
                        {item.dateLabel}
                      </time>
                    )}
                    {item.description && <p class="home-card-desc">{item.description}</p>}
                  </div>
                </a>
              ))}
            </div>
            <div class="home-more-wrap">
              <a class="home-more" href={col.moreHref}>
                查看更多
              </a>
            </div>
          </section>
        ))
      }
    </div>
  </main>
</HomeLayout>
