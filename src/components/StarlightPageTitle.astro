---
import { dailyHeadingTitle } from "../lib/homeLists.ts"

const { entry } = Astro.locals.starlightRoute
const displayTitle = dailyHeadingTitle(entry.id, entry.data)
---

<h1 id="_top">{displayTitle}</h1>

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
  }
</style>
